{
  "apiVersion": "dashboard.grafana.app/v1beta1",
  "kind": "Dashboard",
  "metadata": {
    "name": "machine-detail-s1"
  },
  "spec": {
    "title": "Machine Detail",
    "uid": "machine-detail-s1",
    "schemaVersion": 42,
    "refresh": "30s",
    "timezone": "browser",
    "time": { "from": "now-24h", "to": "now" },
    "timepicker": { "refresh_intervals": ["5s","30s","1m","5m"] },
    "fiscalYearStartMonth": 0,
    "graphTooltip": 1,
    "preload": false,
    "editable": true,
    "tags": ["detail"],
    "links": [],
    "annotations": { "list": [] },
    "templating": {
      "list": [
        {
          "name": "machine",
          "label": "Machine",
          "description": "Select a device to inspect",
          "type": "query",
          "datasource": { "type": "mssql", "uid": "PAAAEB8D7872B0C49" },
          "definition": "SELECT machine_name AS __text, id AS __value FROM dbo.devices ORDER BY customer, location, machine_name",
          "query": "SELECT machine_name AS __text, id AS __value FROM dbo.devices ORDER BY customer, location, machine_name",
          "refresh": 1,
          "regex": "",
          "sort": 0,
          "includeAll": false,
          "allowCustomValue": false,
          "current": {},
          "options": []
        }
      ]
    },
    "panels": [
      {
        "id": 1,
        "type": "stat",
        "title": "Status",
        "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
        "datasource": { "type": "mssql", "uid": "PAAAEB8D7872B0C49" },
        "options": {
          "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
          "colorMode": "background",
          "graphMode": "none",
          "justifyMode": "center",
          "textMode": "auto",
          "orientation": "auto"
        },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "mappings": [
              { "type": "value", "options": { "online": { "text": "🟢 Online", "color": "dark-green", "index": 0 }, "offline": { "text": "🔴 Offline", "color": "dark-red", "index": 1 } } }
            ],
            "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": 0 }] }
          },
          "overrides": []
        },
        "targets": [
          {
            "datasource": { "type": "mssql", "uid": "PAAAEB8D7872B0C49" },
            "editorMode": "code",
            "format": "table",
            "rawQuery": true,
            "rawSql": "SELECT TOP 1 status AS [Status]\nFROM dbo.device_status\nWHERE device_id = ${machine}\nORDER BY ts_datetime DESC",
            "refId": "A"
          }
        ]
      },
      {
        "id": 2,
        "type": "stat",
        "title": "OS Version",
        "gridPos": { "x": 4, "y": 0, "w": 5, "h": 4 },
        "datasource": { "type": "mssql", "uid": "PAAAEB8D7872B0C49" },
        "options": {
          "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
          "colorMode": "background",
          "graphMode": "none",
          "justifyMode": "center",
          "textMode": "auto",
          "orientation": "auto"
        },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "fixed", "fixedColor": "blue" },
            "mappings": [
              { "type": "value", "options": {
                "Microsoft Windows NT 10.0.26100.0": { "text": "Win 11 24H2", "index": 0 },
                "Microsoft Windows NT 10.0.22631.0": { "text": "Win 11 23H2", "index": 1 },
                "Microsoft Windows NT 10.0.22621.0": { "text": "Win 11 22H2", "index": 2 },
                "Microsoft Windows NT 10.0.19045.0": { "text": "Win 10 22H2", "index": 3 },
                "Microsoft Windows NT 10.0.19044.0": { "text": "Win 10 21H2", "index": 4 }
              }}
            ],
            "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": 0 }] }
          },
          "overrides": []
        },
        "targets": [
          {
            "datasource": { "type": "mssql", "uid": "PAAAEB8D7872B0C49" },
            "editorMode": "code",
            "format": "table",
            "rawQuery": true,
            "rawSql": "SELECT TOP 1 os_version AS [OS]\nFROM dbo.device_os_status\nWHERE device_id = ${machine}\nORDER BY ts_datetime DESC",
            "refId": "A"
          }
        ]
      },
      {
        "id": 3,
        "type": "stat",
        "title": "C: Drive Used",
        "gridPos": { "x": 9, "y": 0, "w": 4, "h": 4 },
        "datasource": { "type": "mssql", "uid": "PAAAEB8D7872B0C49" },
        "options": {
          "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
          "colorMode": "background",
          "graphMode": "none",
          "justifyMode": "center",
          "textMode": "auto",
          "orientation": "auto"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "decimals": 1,
            "color": { "mode": "thresholds" },
            "mappings": [],
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "dark-green", "value": 0 },
                { "color": "dark-orange", "value": 75 },
                { "color": "dark-red", "value": 90 }
              ]
            }
          },
          "overrides": []
        },
        "targets": [
          {
            "datasource": { "type": "mssql", "uid": "PAAAEB8D7872B0C49" },
            "editorMode": "code",
            "format": "table",
            "rawQuery": true,
            "rawSql": "SELECT TOP 1 CAST(usage_percent AS decimal(5,1)) AS [C: Drive %]\nFROM dbo.device_storage_status\nWHERE device_id = ${machine} AND drive = 'C'\nORDER BY ts_datetime DESC",
            "refId": "A"
          }
        ]
      },
      {
        "id": 4,
        "type": "stat",
        "title": "Items Today",
        "gridPos": { "x": 13, "y": 0, "w": 4, "h": 4 },
        "datasource": { "type": "mssql", "uid": "PAAAEB8D7872B0C49" },
        "options": {
          "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
          "colorMode": "background",
          "graphMode": "none",
          "justifyMode": "center",
          "textMode": "auto",
          "orientation": "auto"
        },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "fixed", "fixedColor": "purple" },
            "mappings": [],
            "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": 0 }] }
          },
          "overrides": []
        },
        "targets": [
          {
            "datasource": { "type": "mssql", "uid": "PAAAEB8D7872B0C49" },
            "editorMode": "code",
            "format": "table",
            "rawQuery": true,
            "rawSql": "SELECT COALESCE(SUM(total_items),0) AS [Items Today]\nFROM dbo.device_statistics\nWHERE device_id = ${machine}\nAND ts_datetime >= CAST(GETDATE() AS date)\nAND ts_datetime < DATEADD(DAY,1,CAST(GETDATE() AS date))",
            "refId": "A"
          }
        ]
      },
      {
        "id": 5,
        "type": "stat",
        "title": "Good Read % Today",
        "gridPos": { "x": 17, "y": 0, "w": 4, "h": 4 },
        "datasource": { "type": "mssql", "uid": "PAAAEB8D7872B0C49" },
        "options": {
          "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
          "colorMode": "background",
          "graphMode": "none",
          "justifyMode": "center",
          "textMode": "auto",
          "orientation": "auto"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "decimals": 1,
            "color": { "mode": "thresholds" },
            "mappings": [],
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "dark-red", "value": 0 },
                { "color": "dark-orange", "value": 80 },
                { "color": "dark-green", "value": 97 }
              ]
            }
          },
          "overrides": []
        },
        "targets": [
          {
            "datasource": { "type": "mssql", "uid": "PAAAEB8D7872B0C49" },
            "editorMode": "code",
            "format": "table",
            "rawQuery": true,
            "rawSql": "SELECT CAST(COALESCE(100.0*SUM(good_read)/NULLIF(SUM(total_items),0),0) AS decimal(5,1)) AS [Good Read %]\nFROM dbo.device_statistics\nWHERE device_id = ${machine}\nAND ts_datetime >= CAST(GETDATE() AS date)\nAND ts_datetime < DATEADD(DAY,1,CAST(GETDATE() AS date))",
            "refId": "A"
          }
        ]
      },
      {
        "id": 6,
        "type": "stat",
        "title": "Customer / Location",
        "gridPos": { "x": 21, "y": 0, "w": 3, "h": 4 },
        "datasource": { "type": "mssql", "uid": "PAAAEB8D7872B0C49" },
        "options": {
          "reduceOptions": { "calcs": ["lastNotNull"], "fields": "/.*/" , "values": true },
          "colorMode": "none",
          "graphMode": "none",
          "justifyMode": "center",
          "textMode": "value",
          "orientation": "vertical"
        },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "fixed", "fixedColor": "text" },
            "mappings": [],
            "thresholds": { "mode": "absolute", "steps": [{ "color": "text", "value": 0 }] }
          },
          "overrides": []
        },
        "targets": [
          {
            "datasource": { "type": "mssql", "uid": "PAAAEB8D7872B0C49" },
            "editorMode": "code",
            "format": "table",
            "rawQuery": true,
            "rawSql": "SELECT customer AS [Customer], location AS [Location] FROM dbo.devices WHERE id = ${machine}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 30,
        "type": "timeseries",
        "title": "Items Processed Over Time",
        "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
        "datasource": { "type": "mssql", "uid": "PAAAEB8D7872B0C49" },
        "options": {
          "tooltip": { "mode": "single", "sort": "none" },
          "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
        },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 15,
              "gradientMode": "none",
              "drawStyle": "line",
              "pointSize": 4,
              "showPoints": "auto",
              "spanNulls": false,
              "axisPlacement": "auto",
              "axisLabel": "",
              "scaleDistribution": { "type": "linear" },
              "hideFrom": { "legend": false, "tooltip": false, "viz": false }
            },
            "mappings": [],
            "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }] }
          },
          "overrides": []
        },
        "targets": [
          {
            "datasource": { "type": "mssql", "uid": "PAAAEB8D7872B0C49" },
            "editorMode": "code",
            "format": "time_series",
            "rawQuery": true,
            "rawSql": "SELECT ts_datetime AS time, total_items AS [Total Items], good_read AS [Good Reads], no_read AS [No Reads]\nFROM dbo.device_statistics\nWHERE device_id = ${machine}\nAND $__timeFilter(ts_datetime)\nORDER BY ts_datetime",
            "refId": "A"
          }
        ]
      },
      {
        "id": 31,
        "type": "timeseries",
        "title": "Good Read % Over Time",
        "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
        "datasource": { "type": "mssql", "uid": "PAAAEB8D7872B0C49" },
        "options": {
          "tooltip": { "mode": "single", "sort": "none" },
          "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "color": { "mode": "fixed", "fixedColor": "green" },
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 20,
              "gradientMode": "opacity",
              "drawStyle": "line",
              "pointSize": 4,
              "showPoints": "auto",
              "spanNulls": false,
              "axisPlacement": "auto",
              "scaleDistribution": { "type": "linear" },
              "hideFrom": { "legend": false, "tooltip": false, "viz": false }
            },
            "mappings": [],
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "dark-red", "value": 0 },
                { "color": "dark-orange", "value": 80 },
                { "color": "dark-green", "value": 97 }
              ]
            }
          },
          "overrides": []
        },
        "targets": [
          {
            "datasource": { "type": "mssql", "uid": "PAAAEB8D7872B0C49" },
            "editorMode": "code",
            "format": "time_series",
            "rawQuery": true,
            "rawSql": "SELECT ts_datetime AS time,\n  CAST(CASE WHEN total_items > 0 THEN 100.0*good_read/total_items ELSE NULL END AS decimal(6,2)) AS [Good Read %]\nFROM dbo.device_statistics\nWHERE device_id = ${machine}\nAND $__timeFilter(ts_datetime)\nORDER BY ts_datetime",
            "refId": "A"
          }
        ]
      },
      {
        "id": 40,
        "type": "gauge",
        "title": "No Dimensions %",
        "gridPos": { "x": 0, "y": 12, "w": 6, "h": 5 },
        "datasource": { "type": "mssql", "uid": "PAAAEB8D7872B0C49" },
        "options": {
          "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
          "orientation": "auto",
          "showThresholdLabels": false,
          "showThresholdMarkers": true
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "decimals": 1,
            "min": 0,
            "max": 10,
            "color": { "mode": "thresholds" },
            "mappings": [],
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "dark-green", "value": 0 },
                { "color": "dark-orange", "value": 1 },
                { "color": "dark-red", "value": 3 }
              ]
            }
          },
          "overrides": []
        },
        "targets": [
          {
            "datasource": { "type": "mssql", "uid": "PAAAEB8D7872B0C49" },
            "editorMode": "code",
            "format": "table",
            "rawQuery": true,
            "rawSql": "SELECT CAST(COALESCE(100.0*SUM(no_dimension)/NULLIF(SUM(total_items),0),0) AS decimal(5,1)) AS [No Dims %]\nFROM dbo.device_statistics\nWHERE device_id = ${machine}\nAND $__timeFilter(ts_datetime)",
            "refId": "A"
          }
        ]
      },
      {
        "id": 41,
        "type": "gauge",
        "title": "No Weight %",
        "gridPos": { "x": 6, "y": 12, "w": 6, "h": 5 },
        "datasource": { "type": "mssql", "uid": "PAAAEB8D7872B0C49" },
        "options": {
          "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
          "orientation": "auto",
          "showThresholdLabels": false,
          "showThresholdMarkers": true
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "decimals": 1,
            "min": 0,
            "max": 10,
            "color": { "mode": "thresholds" },
            "mappings": [],
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "dark-green", "value": 0 },
                { "color": "dark-orange", "value": 1 },
                { "color": "dark-red", "value": 3 }
              ]
            }
          },
          "overrides": []
        },
        "targets": [
          {
            "datasource": { "type": "mssql", "uid": "PAAAEB8D7872B0C49" },
            "editorMode": "code",
            "format": "table",
            "rawQuery": true,
            "rawSql": "SELECT CAST(COALESCE(100.0*SUM(no_weight)/NULLIF(SUM(total_items),0),0) AS decimal(5,1)) AS [No Weight %]\nFROM dbo.device_statistics\nWHERE device_id = ${machine}\nAND $__timeFilter(ts_datetime)",
            "refId": "A"
          }
        ]
      },
      {
        "id": 42,
        "type": "gauge",
        "title": "Out of Spec %",
        "gridPos": { "x": 12, "y": 12, "w": 6, "h": 5 },
        "datasource": { "type": "mssql", "uid": "PAAAEB8D7872B0C49" },
        "options": {
          "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
          "orientation": "auto",
          "showThresholdLabels": false,
          "showThresholdMarkers": true
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "decimals": 1,
            "min": 0,
            "max": 10,
            "color": { "mode": "thresholds" },
            "mappings": [],
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "dark-green", "value": 0 },
                { "color": "dark-orange", "value": 1 },
                { "color": "dark-red", "value": 5 }
              ]
            }
          },
          "overrides": []
        },
        "targets": [
          {
            "datasource": { "type": "mssql", "uid": "PAAAEB8D7872B0C49" },
            "editorMode": "code",
            "format": "table",
            "rawQuery": true,
            "rawSql": "SELECT CAST(COALESCE(100.0*SUM(item_out_of_spec)/NULLIF(SUM(total_items),0),0) AS decimal(5,1)) AS [Out of Spec %]\nFROM dbo.device_statistics\nWHERE device_id = ${machine}\nAND $__timeFilter(ts_datetime)",
            "refId": "A"
          }
        ]
      },
      {
        "id": 43,
        "type": "gauge",
        "title": "Multiple Items %",
        "gridPos": { "x": 18, "y": 12, "w": 6, "h": 5 },
        "datasource": { "type": "mssql", "uid": "PAAAEB8D7872B0C49" },
        "options": {
          "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
          "orientation": "auto",
          "showThresholdLabels": false,
          "showThresholdMarkers": true
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "decimals": 1,
            "min": 0,
            "max": 10,
            "color": { "mode": "thresholds" },
            "mappings": [],
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "dark-green", "value": 0 },
                { "color": "dark-orange", "value": 3 },
                { "color": "dark-red", "value": 10 }
              ]
            }
          },
          "overrides": []
        },
        "targets": [
          {
            "datasource": { "type": "mssql", "uid": "PAAAEB8D7872B0C49" },
            "editorMode": "code",
            "format": "table",
            "rawQuery": true,
            "rawSql": "SELECT CAST(COALESCE(100.0*SUM(more_than_1_item)/NULLIF(SUM(total_items),0),0) AS decimal(5,1)) AS [Multiple Items %]\nFROM dbo.device_statistics\nWHERE device_id = ${machine}\nAND $__timeFilter(ts_datetime)",
            "refId": "A"
          }
        ]
      },
      {
        "id": 50,
        "type": "table",
        "title": "Drive Storage",
        "gridPos": { "x": 0, "y": 17, "w": 10, "h": 6 },
        "datasource": { "type": "mssql", "uid": "PAAAEB8D7872B0C49" },
        "options": {
          "cellHeight": "sm",
          "showHeader": true,
          "enablePagination": false,
          "sortBy": [{ "displayName": "Drive", "desc": false }]
        },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "custom": { "align": "center", "cellOptions": { "type": "auto" }, "inspect": false },
            "mappings": [],
            "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }] }
          },
          "overrides": [
            {
              "matcher": { "id": "byName", "options": "Used %" },
              "properties": [
                { "id": "unit", "value": "percent" },
                { "id": "min", "value": 0 },
                { "id": "max", "value": 100 },
                { "id": "custom.cellOptions", "value": { "type": "gauge", "mode": "basic", "valueDisplayMode": "color" } },
                { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "dark-green", "value": 0 }, { "color": "dark-orange", "value": 75 }, { "color": "dark-red", "value": 90 }] } }
              ]
            },
            {
              "matcher": { "id": "byName", "options": "Total GB" },
              "properties": [{ "id": "unit", "value": "decgbytes" }, { "id": "decimals", "value": 1 }]
            },
            {
              "matcher": { "id": "byName", "options": "Free GB" },
              "properties": [{ "id": "unit", "value": "decgbytes" }, { "id": "decimals", "value": 1 }]
            },
            {
              "matcher": { "id": "byName", "options": "Used GB" },
              "properties": [{ "id": "unit", "value": "decgbytes" }, { "id": "decimals", "value": 1 }]
            }
          ]
        },
        "targets": [
          {
            "datasource": { "type": "mssql", "uid": "PAAAEB8D7872B0C49" },
            "editorMode": "code",
            "format": "table",
            "rawQuery": true,
            "rawSql": "SELECT x.drive AS [Drive], x.total_gb AS [Total GB], x.used_gb AS [Used GB], x.free_gb AS [Free GB], CAST(x.usage_percent AS decimal(5,1)) AS [Used %]\nFROM (\n  SELECT drive, total_gb, free_gb, used_gb, usage_percent,\n         ROW_NUMBER() OVER (PARTITION BY drive ORDER BY ts_datetime DESC) AS rn\n  FROM dbo.device_storage_status\n  WHERE device_id = ${machine}\n) x WHERE x.rn = 1\nORDER BY x.drive",
            "refId": "A"
          }
        ]
      },
      {
        "id": 51,
        "type": "timeseries",
        "title": "Data Transmission — Sent vs Not Sent",
        "gridPos": { "x": 10, "y": 17, "w": 14, "h": 6 },
        "datasource": { "type": "mssql", "uid": "PAAAEB8D7872B0C49" },
        "options": {
          "tooltip": { "mode": "multi", "sort": "none" },
          "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
        },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 10,
              "gradientMode": "none",
              "drawStyle": "line",
              "pointSize": 4,
              "showPoints": "auto",
              "spanNulls": false,
              "axisPlacement": "auto",
              "scaleDistribution": { "type": "linear" },
              "hideFrom": { "legend": false, "tooltip": false, "viz": false }
            },
            "mappings": [],
            "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }] }
          },
          "overrides": []
        },
        "targets": [
          {
            "datasource": { "type": "mssql", "uid": "PAAAEB8D7872B0C49" },
            "editorMode": "code",
            "format": "time_series",
            "rawQuery": true,
            "rawSql": "SELECT ts_datetime AS time, data_sent AS [Data Sent], not_sent AS [Not Sent], image_sent AS [Images Sent], image_not_sent AS [Images Not Sent]\nFROM dbo.device_statistics\nWHERE device_id = ${machine}\nAND $__timeFilter(ts_datetime)\nORDER BY ts_datetime",
            "refId": "A"
          }
        ]
      }
    ]
  }
}
