            "rawSql": "WITH device_scope AS (\n  SELECT d.id, d.customer, d.location, d.machine_name\n  FROM dbo.devices d\n  WHERE (${tenant:sqlstring} = '__ALL__' OR d.customer = ${tenant:sqlstring})\n),\nlatest_status AS (\n  SELECT x.device_id, x.status FROM (\n    SELECT ds.device_id, ds.status,\n           ROW_NUMBER() OVER (PARTITION BY ds.device_id ORDER BY ds.ts_datetime DESC) AS rn\n    FROM dbo.device_status ds\n  ) x WHERE x.rn = 1\n),\nlatest_os AS (\n  SELECT x.device_id, x.os_version FROM (\n    SELECT os.device_id, os.os_version,\n           ROW_NUMBER() OVER (PARTITION BY os.device_id ORDER BY os.ts_datetime DESC) AS rn\n    FROM dbo.device_os_status os\n  ) x WHERE x.rn = 1\n),\nlatest_c_drive AS (\n  SELECT x.device_id, x.usage_percent FROM (\n    SELECT ss.device_id, ss.usage_percent,\n           ROW_NUMBER() OVER (PARTITION BY ss.device_id ORDER BY ss.ts_datetime DESC) AS rn\n    FROM dbo.device_storage_status ss WHERE ss.drive = 'C'\n  ) x WHERE x.rn = 1\n),\nstats AS (\n  SELECT ds.device_id,\n    SUM(ds.total_items) AS total_items,\n    SUM(ds.good_read)   AS good_read,\n    SUM(ds.no_dimension) AS no_dimension,\n    SUM(ds.no_weight)   AS no_weight\n  FROM dbo.device_statistics ds\n  WHERE ds.ts_datetime \u003e= CAST(GETDATE() AS date)\n  AND ds.ts_datetime \u003c DATEADD(DAY,1,CAST(GETDATE() AS date))\n  GROUP BY ds.device_id\n)\nSELECT\n  sc.customer                                                    AS [Customer],\n  sc.location                                                    AS [Location],\n  sc.machine_name                                                AS [Machine],\n  COALESCE(ls.status, 'unknown')                                 AS [Status],\n  COALESCE(\n    CASE\n      WHEN lo.os_version LIKE '%10.0.26100%' THEN 'Win 11 24H2'\n      WHEN lo.os_version LIKE '%10.0.22631%' THEN 'Win 11 23H2'\n      WHEN lo.os_version LIKE '%10.0.22621%' THEN 'Win 11 22H2'\n      WHEN lo.os_version LIKE '%10.0.22000%' THEN 'Win 11 21H2'\n      WHEN lo.os_version LIKE '%10.0.19045%' THEN 'Win 10 22H2'\n      WHEN lo.os_version LIKE '%10.0.19044%' THEN 'Win 10 21H2'\n      ELSE 'Unknown'\n    END, 'Unknown'\n  )                                                              AS [OS Version],\n  CAST(COALESCE(lc.usage_percent, 0) AS decimal(5,1))           AS [C: Drive %],\n  COALESCE(st.total_items, 0)                                    AS [Items Today],\n  CAST(COALESCE(100.0*st.good_read/NULLIF(st.total_items,0),0) AS decimal(5,1)) AS [Good Read %],\n  CAST(COALESCE(100.0*st.no_dimension/NULLIF(st.total_items,0),0) AS decimal(5,1)) AS [No Dims %],\n  CAST(COALESCE(100.0*st.no_weight/NULLIF(st.total_items,0),0) AS decimal(5,1))   AS [No Weight %]\nFROM device_scope sc\nLEFT JOIN latest_status  ls ON ls.device_id = sc.id\nLEFT JOIN latest_os      lo ON lo.device_id = sc.id\nLEFT JOIN latest_c_drive lc ON lc.device_id = sc.id\nLEFT JOIN stats          st ON st.device_id = sc.id\nORDER BY sc.customer, sc.location, sc.machine_name",
            "refId": "A"
          }
        ],
        "title": "Device Overview",
        "type": "table"
      },
