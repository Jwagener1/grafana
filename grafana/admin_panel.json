            "rawSql": "SELECT\n  RIGHT('0'+CAST(DATEPART(HOUR, ts_datetime) AS varchar),2)+':00' AS [Hour],\n  SUM(total_items) AS [Items]\nFROM dbo.device_statistics ds\nJOIN dbo.devices d ON d.id = ds.device_id\nWHERE ds.ts_datetime \u003e= CAST(GETDATE() AS date)\nAND ds.ts_datetime \u003c DATEADD(DAY,1,CAST(GETDATE() AS date))\nAND (${tenant:sqlstring} = '__ALL__' OR d.customer = ${tenant:sqlstring})\nGROUP BY DATEPART(HOUR, ts_datetime)\nORDER BY DATEPART(HOUR, ts_datetime)",
