            "rawQuery": true,
            "rawSql": "SELECT\n  d.machine_name AS [Machine],\n  CAST(COALESCE(100.0*SUM(ds.good_read)/NULLIF(SUM(ds.total_items),0),0) AS decimal(5,1)) AS [Good Read %]\nFROM dbo.device_statistics ds\nJOIN dbo.devices d ON d.id = ds.device_id\nWHERE ds.ts_datetime >= CAST(GETDATE() AS date)\nAND ds.ts_datetime < DATEADD(DAY,1,CAST(GETDATE() AS date))\nAND (${tenant:sqlstring} = '__ALL__' OR d.customer = ${tenant:sqlstring})\nGROUP BY d.machine_name\nORDER BY [Good Read %] ASC",
            "refId": "A"
