            "editorMode": "code",
            "format": "table",
            "rawQuery": true,
            "rawSql": "SELECT COUNT(*) AS [Online Now]\nFROM (\n  SELECT x.device_id FROM (\n    SELECT ds.device_id, ds.status,\n           ROW_NUMBER() OVER (PARTITION BY ds.device_id ORDER BY ds.ts_datetime DESC) AS rn\n    FROM dbo.device_status ds\n    JOIN dbo.devices d ON d.id = ds.device_id\n    WHERE (${tenant:sqlstring} = '__ALL__' OR d.customer = ${tenant:sqlstring})\n  ) x WHERE x.rn = 1 AND x.status = 'online'\n) t",
            "refId": "A"
          }
        ],
        "title": "Online Now",
        "type": "stat"
