            "editorMode": "code",
            "format": "table",
            "rawQuery": true,
            "rawSql": "WITH base AS (\r\n    SELECT\r\n        ds.device_id,\r\n        ds.ts_datetime,\r\n        ds.total_items,\r\n        ds.good_read\r\n    FROM dbo.device_statistics ds\r\n    WHERE ds.device_id IN (${pepkor_devices:csv})\r\n),\r\nperiods AS (\r\n    SELECT\r\n        1 AS sort_order,\r\n        'Year' AS period,\r\n        DATEFROMPARTS(YEAR(GETDATE()), 1, 1) AS start_dt,\r\n        DATEADD(YEAR, 1, DATEFROMPARTS(YEAR(GETDATE()), 1, 1)) AS end_dt\r\n    UNION ALL\r\n    SELECT\r\n        2,\r\n        'Month',\r\n        DATEFROMPARTS(YEAR(GETDATE()), MONTH(GETDATE()), 1),\r\n        DATEADD(MONTH, 1, DATEFROMPARTS(YEAR(GETDATE()), MONTH(GETDATE()), 1))\r\n    UNION ALL\r\n    SELECT\r\n        3,\r\n        'Day',\r\n        CAST(GETDATE() AS date),\r\n        DATEADD(DAY, 1, CAST(GETDATE() AS date))\r\n)\r\nSELECT\r\n    p.period,\r\n    SUM(b.total_items) AS total_parcels,\r\n    CAST(100.0 * SUM(b.good_read) / NULLIF(SUM(b.total_items), 0) AS decimal(6,2)) AS good_read_pct\r\nFROM periods p\r\nLEFT JOIN base b\r\n    ON b.ts_datetime \u003e= p.start_dt\r\n   AND b.ts_datetime \u003c  p.end_dt\r\nGROUP BY\r\n    p.sort_order,\r\n    p.period\r\nORDER BY\r\n    p.sort_order;\r\n",
            "refId": "A",
