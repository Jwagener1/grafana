        "targets": [
          {
            "dataset": "S1_Remote_Monitoring",
            "editorMode": "code",
            "format": "table",
            "rawQuery": true,
            "rawSql": "WITH latest_stats AS (\r\n    SELECT\r\n        x.device_id,\r\n        x.ts_datetime AS last_statistics_ts\r\n    FROM (\r\n        SELECT\r\n            ds.device_id,\r\n            ds.ts_datetime,\r\n            ROW_NUMBER() OVER (\r\n                PARTITION BY ds.device_id\r\n                ORDER BY ds.ts_datetime DESC\r\n            ) AS rn\r\n        FROM dbo.device_statistics ds\r\n    ) x\r\n    WHERE x.rn = 1\r\n)\r\nSELECT\r\n    CONCAT(d.location, ' - ', d.machine_name) AS device_name,\r\n    CASE\r\n        WHEN lstat.last_statistics_ts IS NULL THEN NULL\r\n        ELSE\r\n            CONCAT(\r\n                CASE\r\n                    WHEN DATEDIFF(MINUTE, lstat.last_statistics_ts, SYSDATETIME()) / 1440 \u003e 0\r\n                        THEN CONCAT(DATEDIFF(MINUTE, lstat.last_statistics_ts, SYSDATETIME()) / 1440, 'd ')\r\n                    ELSE ''\r\n                END,\r\n                RIGHT('0' + CAST((DATEDIFF(MINUTE, lstat.last_statistics_ts, SYSDATETIME()) % 1440) / 60 AS varchar(2)), 2),\r\n                'h ',\r\n                RIGHT('0' + CAST(DATEDIFF(MINUTE, lstat.last_statistics_ts, SYSDATETIME()) % 60 AS varchar(2)), 2),\r\n                'm'\r\n            )\r\n    END AS time_since_last_packet\r\nFROM dbo.devices d\r\nLEFT JOIN latest_stats lstat\r\n    ON lstat.device_id = d.id\r\nWHERE d.customer = '${Customer}'\r\nORDER BY\r\n    d.location,\r\n    d.machine_name;\r\n",
            "refId": "A",
            "sql": {
              "columns": [
                {
                  "parameters": [],
                  "type": "function"
                }
              ],
              "groupBy": [
                {
                  "property": {
                    "type": "string"
                  },
                  "type": "groupBy"
                }
              ],
              "limit": 50
            }
          }
        ],
