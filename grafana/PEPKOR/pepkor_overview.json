            "editorMode": "code",
            "format": "table",
            "rawQuery": true,
            "rawSql": "WITH base AS (\r\n    SELECT\r\n        ds.ts_datetime,\r\n        ds.total_items,\r\n        ds.good_read\r\n    FROM dbo.device_statistics ds\r\n    WHERE ds.device_id IN (${pepkor_devices:csv})\r\n),\r\nbounds AS (\r\n    SELECT\r\n        CAST(GETDATE() AS datetime2(7)) AS now_dt,\r\n        CAST(GETDATE() AS date) AS day_start,\r\n        DATEADD(DAY, 1, CAST(GETDATE() AS date)) AS day_end,\r\n        DATEFROMPARTS(YEAR(GETDATE()), MONTH(GETDATE()), 1) AS month_start,\r\n        DATEADD(MONTH, 1, DATEFROMPARTS(YEAR(GETDATE()), MONTH(GETDATE()), 1)) AS month_end,\r\n        DATEFROMPARTS(YEAR(GETDATE()), 1, 1) AS year_start,\r\n        DATEADD(YEAR, 1, DATEFROMPARTS(YEAR(GETDATE()), 1, 1)) AS year_end\r\n)\r\nSELECT\r\n    -- Year\r\n    SUM(CASE WHEN b.ts_datetime \u003e= bo.year_start AND b.ts_datetime \u003c bo.year_end THEN b.total_items ELSE 0 END) AS year_total_parcels,\r\n    CAST(\r\n        100.0 * SUM(CASE WHEN b.ts_datetime \u003e= bo.year_start AND b.ts_datetime \u003c bo.year_end THEN b.good_read ELSE 0 END)\r\n        / NULLIF(SUM(CASE WHEN b.ts_datetime \u003e= bo.year_start AND b.ts_datetime \u003c bo.year_end THEN b.total_items ELSE 0 END), 0)\r\n        AS decimal(6,2)\r\n    ) AS year_good_read_pct,\r\n\r\n    -- Month\r\n    SUM(CASE WHEN b.ts_datetime \u003e= bo.month_start AND b.ts_datetime \u003c bo.month_end THEN b.total_items ELSE 0 END) AS month_total_parcels,\r\n    CAST(\r\n        100.0 * SUM(CASE WHEN b.ts_datetime \u003e= bo.month_start AND b.ts_datetime \u003c bo.month_end THEN b.good_read ELSE 0 END)\r\n        / NULLIF(SUM(CASE WHEN b.ts_datetime \u003e= bo.month_start AND b.ts_datetime \u003c bo.month_end THEN b.total_items ELSE 0 END), 0)\r\n        AS decimal(6,2)\r\n    ) AS month_good_read_pct,\r\n\r\n    -- Day\r\n    SUM(CASE WHEN b.ts_datetime \u003e= bo.day_start AND b.ts_datetime \u003c bo.day_end THEN b.total_items ELSE 0 END) AS day_total_parcels,\r\n    CAST(\r\n        100.0 * SUM(CASE WHEN b.ts_datetime \u003e= bo.day_start AND b.ts_datetime \u003c bo.day_end THEN b.good_read ELSE 0 END)\r\n        / NULLIF(SUM(CASE WHEN b.ts_datetime \u003e= bo.day_start AND b.ts_datetime \u003c bo.day_end THEN b.total_items ELSE 0 END), 0)\r\n        AS decimal(6,2)\r\n    ) AS day_good_read_pct\r\nFROM base b\r\nCROSS JOIN bounds bo;\r\n",
            "refId": "A",
