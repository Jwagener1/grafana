            "dataset": "S1_Remote_Monitoring",
            "editorMode": "code",
            "format": "table",
            "rawQuery": true,
            "rawSql": "SELECT\r\n    CONCAT(d.location, ' - ', d.machine_name) AS device_name,\r\n\r\n    CAST(\r\n        100.0 * SUM(COALESCE(ds.no_read, 0)) / NULLIF(SUM(COALESCE(ds.total_items, 0)), 0)\r\n        AS decimal(6,2)\r\n    ) AS no_read_pct,\r\n\r\n    CAST(\r\n        100.0 * SUM(COALESCE(ds.no_dimension, 0)) / NULLIF(SUM(COALESCE(ds.total_items, 0)), 0)\r\n        AS decimal(6,2)\r\n    ) AS no_dimension_pct,\r\n\r\n    CAST(\r\n        100.0 * SUM(COALESCE(ds.item_out_of_spec, 0)) / NULLIF(SUM(COALESCE(ds.total_items, 0)), 0)\r\n        AS decimal(6,2)\r\n    ) AS item_out_of_spec_pct,\r\n\r\n    CAST(\r\n        100.0 * SUM(COALESCE(ds.more_than_1_item, 0)) / NULLIF(SUM(COALESCE(ds.total_items, 0)), 0)\r\n        AS decimal(6,2)\r\n    ) AS more_than_1_item_pct\r\n\r\nFROM dbo.devices d\r\nLEFT JOIN dbo.device_statistics ds\r\n    ON ds.device_id = d.id\r\n   AND $__timeFilter(ds.ts_datetime)\r\nWHERE d.customer = '${Customer}'\r\nGROUP BY\r\n    d.location,\r\n    d.machine_name\r\nORDER BY\r\n    d.location,\r\n    d.machine_name;\r\n",
            "refId": "A",
            "sql": {
